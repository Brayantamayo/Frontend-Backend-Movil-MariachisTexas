generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model Usuario {
  id        Int       @id @default(autoincrement())
  nombre    String
  email     String    @unique
  password  String
  estado    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  rolId     Int
  cliente   Cliente?
  empleado  Empleado?
  rol       Rol       @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@map("usuario")
}

model Empleado {
  id                   Int           @id @default(autoincrement())
  usuarioId            Int           @unique
  tipoDocumento        TipoDocumento @default(CC)
  numeroDocumento      String        @unique
  fechaNacimiento      DateTime
  telefonoPrincipal    String
  telefonoAlternativo  String?
  ciudad               String        @default("Medellín")
  barrio               String
  direccion            String
  zonaServicio         ZonaServicio  @default(URBANA)
  instrumentoPrincipal String
  otrosInstrumentos    String?
  anosExperiencia      Int           @default(0)
  foto                 String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  usuario              Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("empleado")
}

model Rol {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  descripcion String?
  estado      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rolPermisos RolPermiso[]
  usuarios    Usuario[]

  @@map("rol")
}

model RolPermiso {
  id        Int      @id @default(autoincrement())
  rolId     Int
  permisoId Int
  createdAt DateTime @default(now())
  permiso   Permiso  @relation(fields: [permisoId], references: [id], onDelete: Cascade)
  rol       Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
  @@map("rol_permiso")
}

model Permiso {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  estado      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rolPermisos RolPermiso[]

  @@map("permiso")
}

model Cliente {
  id                  Int           @id @default(autoincrement())
  foto                String?
  apellido            String
  tipoDocumento       TipoDocumento @default(CC)
  numeroDocumento     String        @unique
  fechaNacimiento     DateTime
  email               String        @unique
  telefonoPrincipal   String
  telefonoAlternativo String?
  ciudad              String        @default("Medellín")
  barrio              String
  direccion           String
  zonaServicio        ZonaServicio  @default(URBANA)
  activo              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  usuarioId           Int           @unique
  abonos              Abono[]
  usuario             Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cotizaciones        Cotizacion[]
  ventas              Venta[]

  @@map("cliente")
}

model Servicio {
  id                  Int                  @id @default(autoincrement())
  nombre              String               @unique
  descripcion         String
  precio              Decimal              @db.Decimal(10, 2)
  estado              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  cotizacionServicios CotizacionServicio[]

  @@map("servicio")
}

model Repertorio {
  id           Int                    @id @default(autoincrement())
  titulo       String
  artista      String
  genero       String
  categoria    String
  letra        String?
  audioUrl     String?
  duracion     String
  dificultad   String
  portada      String?
  activa       Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  cotizaciones CotizacionRepertorio[]
  ensayos      EnsayoRepertorio[]

  @@map("repertorio")
}

model Cotizacion {
  id                Int                    @id @default(autoincrement())
  clienteId         Int?
  nombreHomenajeado String
  tipoEvento        TipoEvento
  fechaEvento       DateTime
  horaInicio        DateTime
  horaFin           DateTime
  direccionEvento   String
  notasAdicionales  String?
  totalEstimado     Decimal?               @db.Decimal(10, 2)
  esReservaDirecta  Boolean                @default(false)
  estado            EstadoCotizacion       @default(EN_ESPERA)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  contactoEmail     String?
  contactoNombre    String?
  contactoTelefono  String?
  contactoTelefono2 String?
  cliente           Cliente?               @relation(fields: [clienteId], references: [id])
  repertorios       CotizacionRepertorio[]
  servicios         CotizacionServicio[]
  reserva           Reserva?

  @@map("cotizacion")
}

model CotizacionServicio {
  id           Int        @id @default(autoincrement())
  cotizacionId Int
  servicioId   Int
  cantidad     Int        @default(1)
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  servicio     Servicio   @relation(fields: [servicioId], references: [id])

  @@unique([cotizacionId, servicioId])
  @@map("cotizacion_servicio")
}

model CotizacionRepertorio {
  id           Int        @id @default(autoincrement())
  cotizacionId Int
  repertorioId Int
  orden        Int        @default(0)
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  repertorio   Repertorio @relation(fields: [repertorioId], references: [id], onDelete: Cascade)

  @@unique([cotizacionId, repertorioId])
  @@map("cotizacion_repertorio")
}

model Reserva {
  id             Int           @id @default(autoincrement())
  cotizacionId   Int           @unique
  totalValor     Decimal       @db.Decimal(10, 2)
  saldoPendiente Decimal       @db.Decimal(10, 2)
  estado         EstadoReserva @default(PENDIENTE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  abonos         Abono[]
  cotizacion     Cotizacion    @relation(fields: [cotizacionId], references: [id])
  venta          Venta?

  @@map("reserva")
}

model Abono {
  id         Int        @id @default(autoincrement())
  reservaId  Int
  clienteId  Int
  monto      Decimal    @db.Decimal(10, 2)
  fechaPago  DateTime
  metodoPago MetodoPago
  notas      String?
  nuevoSaldo Decimal    @db.Decimal(10, 2)
  createdAt  DateTime   @default(now())
  cliente    Cliente    @relation(fields: [clienteId], references: [id])
  reserva    Reserva    @relation(fields: [reservaId], references: [id])

  @@map("abono")
}

model Venta {
  id          Int         @id @default(autoincrement())
  reservaId   Int?        @unique
  clienteId   Int
  tipo        TipoVenta
  estado      EstadoVenta
  montoTotal  Decimal     @db.Decimal(10, 2)
  montoPagado Decimal     @db.Decimal(10, 2)
  fechaVenta  DateTime
  metodoPago  MetodoPago
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cliente     Cliente     @relation(fields: [clienteId], references: [id])
  reserva     Reserva?    @relation(fields: [reservaId], references: [id])

  @@map("venta")
}

model Ensayo {
  id          Int                @id @default(autoincrement())
  nombre      String
  fechaHora   DateTime
  lugar       String
  ubicacion   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  estado      EstadoEnsayo       @default(PENDIENTE)
  repertorios EnsayoRepertorio[]

  @@map("ensayo")
}

model EnsayoRepertorio {
  id           Int        @id @default(autoincrement())
  ensayoId     Int
  repertorioId Int
  ensayo       Ensayo     @relation(fields: [ensayoId], references: [id], onDelete: Cascade)
  repertorio   Repertorio @relation(fields: [repertorioId], references: [id], onDelete: Cascade)

  @@unique([ensayoId, repertorioId])
  @@map("ensayo_repertorio")
}

model BloqueoCalendario {
  id          Int      @id @default(autoincrement())
  fechaInicio DateTime
  fechaFin    DateTime
  motivo      String?
  createdAt   DateTime @default(now())

  @@map("bloqueo_calendario")
}

model PasswordResetOtp {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_otp")
}

model RegistroToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @default(uuid())
  email     String
  nombre    String
  telefono  String
  telefono2 String?
  usado     Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("registro_token")
}

enum TipoDocumento {
  CC
  CE
  PAS
  TI
}

enum ZonaServicio {
  URBANA
  RURAL
}

enum EstadoCotizacion {
  EN_ESPERA
  CONVERTIDA
  ANULADA
}

enum EstadoReserva {
  PENDIENTE
  CONFIRMADA
  ANULADA
  FINALIZADO
}

enum EstadoEnsayo {
  PENDIENTE
  LISTO
}

enum EstadoVenta {
  CONFIRMADO
  FINALIZADO
  VENTA_DIRECTA
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  NEQUI
  DAVIPLATA
  OTRO
  TARJETA
}

enum TipoVenta {
  RESERVA
  DIRECTA
}

enum TipoEvento {
  BODA
  CUMPLEANOS
  QUINCEANIOS
  FUNERAL
  RECONCILIACION
  DIA_DE_MADRE
  OTRO
  AMOR
  ANIVERSARIO
  PADRES
  FIESTA
}
