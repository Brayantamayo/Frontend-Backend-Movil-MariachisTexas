{
  "compilerOptions": {
    "rootDir": "",
    "outDir": "dist",
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*","prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}